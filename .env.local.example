# Supabase — copy this file to .env.local and fill in your project values.
# Project URL + anon key are safe to expose to the browser (used by client + server SSR helpers).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SERVICE ROLE KEY — SERVER ONLY. Never expose to the browser.
# Used only by lib/supabase/admin.ts and the seed script.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
